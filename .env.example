# Shamy pipeline — environment variables
# Copy this to .env locally; production values live in GitHub Actions Secrets.

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Telegram Bot (talk to @BotFather → /newbot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_SNEHA=
TELEGRAM_CHAT_ID_MEHUL=

# Google Drive (OAuth credentials JSON path, or service-account JSON inline)
# For local dev: path to credentials.json. For Actions: paste the JSON into a secret.
GOOGLE_CREDENTIALS_JSON=
DRIVE_ROOT_FOLDER_ID=

# Vizard.ai
VIZARD_API_KEY=

# Timezone for scheduling
TZ=Europe/Berlin

# Pipeline behavior
DRY_RUN=false
LOG_LEVEL=INFO
