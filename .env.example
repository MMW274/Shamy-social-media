# Shamy pipeline — environment variables
# Copy this to .env locally; production values live in GitHub Actions Secrets.

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Telegram Bot (talk to @BotFather → /newbot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_SNEHA=
TELEGRAM_CHAT_ID_MEHUL=

# Google Drive — your filtered photo folder (SHAMY pictures)
# Folder: https://drive.google.com/drive/folders/1U1e_VqaTXzmjWWLEAf9YB72JhaqE4u1u
# Only needed if you run the Python pipeline (not needed for manual Vizard-only posting).
GOOGLE_CREDENTIALS_JSON=
DRIVE_ROOT_FOLDER_ID=1U1e_VqaTXzmjWWLEAf9YB72JhaqE4u1u

# Vizard.ai API key
# Get it: Vizard dashboard → Workspace Settings → API tab
# LOCAL: paste in .env as VIZARD_API_KEY=...
# GITHUB: you stored it as secret name PRODUCTION (workflow reads that)
# NEVER commit the real key.
VIZARD_API_KEY=

# Timezone for scheduling
TZ=Europe/Berlin

# Pipeline behavior
DRY_RUN=false
LOG_LEVEL=INFO
